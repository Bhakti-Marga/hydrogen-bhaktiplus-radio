{
  "name": "media-platform",
  "private": true,
  "sideEffects": false,
  "version": "2025.1.2",
  "type": "module",
  "scripts": {
    "build": "shopify hydrogen build --codegen --force-client-sourcemap",
    "postbuild": "./sentry-upload.sh",
    "dev": "react-router typegen --watch & shopify hydrogen dev --codegen --env-file .env.local",
    "dev:debug": "NODE_OPTIONS='--inspect=9229' shopify hydrogen dev --codegen",
    "preview": "shopify hydrogen preview --build --env-file .env.local",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "codegen": "shopify hydrogen codegen",
    "ngrok": "ngrok http --url=select-moccasin-eagerly.ngrok-free.app 3000",
    "subscription-tester": "npx tsx tools/subscription-tester/server.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.3",
    "@react-router/dev": "^7.9.2",
    "@react-router/fs-routes": "^7.9.2",
    "@sentry/cloudflare": "^10.18.0",
    "@sentry/react-router": "^10.18.0",
    "@shopify/hydrogen": "^2025.7.0",
    "create-hmac": "^1.1.7",
    "date-fns": "^4.1.0",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "hashids": "^2.3.0",
    "isbot": "^5.1.21",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-highlight-words": "^0.21.0",
    "react-router": "^7.9.2",
    "vite-plugin-node-polyfills": "^0.23.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@graphql-codegen/cli": "5.0.2",
    "@sentry/cli": "^2.56.0",
    "@shopify/cli": "^3.85.4",
    "@shopify/hydrogen-codegen": "^0.3.3",
    "@shopify/mini-oxygen": "^4.0.0",
    "@shopify/oxygen-workers-types": "^4.1.6",
    "@shopify/prettier-config": "^1.1.2",
    "@total-typescript/ts-reset": "^0.4.2",
    "@types/create-hmac": "^1.1.3",
    "@types/eslint": "^9.6.1",
    "@types/react": "^18.2.22",
    "@types/react-dom": "^18.2.7",
    "@types/react-highlight-words": "^0.20.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "prettier": "^2.8.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^6.2.7",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "defaults"
  ]
}
